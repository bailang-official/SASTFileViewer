<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SASTFileViewer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SASTFileViewer"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:SASTFileViewer"
    xmlns:models="using:SASTFileViewer.Models"
    mc:Ignorable="d"
    Title="SASTFileViewer">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Padding="12" Spacing="8">
            <Button x:Name="BackButton" Click="BackButton_Click" ToolTipService.ToolTip="返回上一级">
                <SymbolIcon Symbol="Back"/>
            </Button>

            <AutoSuggestBox x:Name="SearchBox" 
                    PlaceholderText="搜索文件..." 
                    QueryIcon="Find" 
                    Width="250"
                    TextChanged="SearchBox_TextChanged" />

            <TextBlock Text="{x:Bind ViewModel.CurrentPath, Mode=OneWay}" 
                   VerticalAlignment="Center" 
                   Foreground="Gray"
                   FontSize="12"/>
        </StackPanel>

        <ListView Grid.Row="1" 
              ItemsSource="{x:Bind ViewModel.Files}"
              IsItemClickEnabled="True" 
              ItemClick="FileListView_ItemClick">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:FileItem">
                    <Grid Padding="12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <SymbolIcon Symbol="{Binding FileIcon}" 
                                        Foreground="{Binding IsFolder, Converter={StaticResource MyColorConverter}}"
                                        Margin="0,0,12,0" />
                            <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Grid.Column="1" Text="{x:Bind FileSize}" VerticalAlignment="Center" Foreground="Gray" FontSize="12"/>
                        <TextBlock Grid.Column="2" Text="{x:Bind LastModified}" VerticalAlignment="Center" Foreground="Gray" FontSize="12"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
